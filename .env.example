# ── OBLIGATORIAS ──────────────────────────────────────────────────────────────

# Clave API de Google Gemini (obtener en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Ruta al archivo JSON de credenciales de la cuenta de servicio de Google Cloud
# (necesario para TTS y STT). Crear carpeta creds/ y poner el JSON ahí.
GOOGLE_APPLICATION_CREDENTIALS=creds\service-account.json

# ID del proyecto en Google Cloud
GOOGLE_CLOUD_PROJECT=

# ── OPCIONALES (tienen valores por defecto) ────────────────────────────────────

# Índice de la cámara (0 = webcam por defecto del sistema)
CAMERA_INDEX=0

# Frames por segundo enviados a Gemini
FRAME_RATE=1

# Configuración de voz TTS
TTS_LANGUAGE_CODE=es-US
TTS_VOICE_NAME=es-US-Neural2-B

# Clave API de Google Maps (solo si se usa navegación en la demo)
GOOGLE_MAPS_API_KEY=
